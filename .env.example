# =============================================
# LaptopAdvisor Environment Variables
# NEVER commit this file to git
# =============================================

NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Anthropic Claude API (server-side only)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Upstash Redis — rate limiting
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Cache admin API
CACHE_ADMIN_KEY=your-random-admin-key-here

# Amazon Associates
AFFILIATE_TAG=your-affiliate-tag-here

# Rainforest API — Amazon product data for laptops
RAINFOREST_API_KEY=your-rainforest-api-key-here
RAINFOREST_CATEGORY_ID=565108

# SerpApi — Google Shopping laptop search (server-side only)
SERPAPI_KEY=your-serpapi-key-here

# Google Gemini API — AI Chat Assistant
GEMINI_API_KEY=your-gemini-api-key-here
